# Telegram
TG_TOKEN=

# Timezone
TZ=Europe/Moscow

# Power BI report rendering
# Можно не задавать REPORT_BASE_URL, если уже есть PBI_HOST/PBI_USER/PBI_PASS
# в .env основного проекта.
REPORT_BASE_URL=http://10.128.0.33/powerbi/?id=
DEFAULT_REPORT_ID=sales/kpi
SELENIUM_HUB_URL=http://selenium:4444/wd/hub
RENDER_WAIT_SECONDS=8
RENDER_TARGET_XPATH=

# Legacy (совместимость с основным проектом)
PBI_HOST=
PBI_USER=
PBI_PASS=

# SQL connection (option 1: DSN)
MSSQL_DSN=

# SQL connection (option 2: host/user/password)
MSSQL_SERVER=10.128.0.11
MSSQL_PORT=1433
MSSQL_DB=beauty-kpi-test
MSSQL_USER=test_user
MSSQL_PWD=
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# Optional Power BI model bridge
POWERBI_MODEL_QUERY_URL=
POWERBI_MODEL_QUERY_TOKEN=

# LLM — Ollama Cloud (модели с тегом :cloud)
OLLAMA_API_KEY=
OLLAMA_MODEL=glm-5:cloud
OLLAMA_BASE_URL=https://ollama.com/api

# STT — Whisper через Ollama Cloud (кастомная модель)
# Если WHISPER_BASE_URL не задан, используется OLLAMA_BASE_URL
WHISPER_BASE_URL=
WHISPER_MODEL=whisper-large:cloud
